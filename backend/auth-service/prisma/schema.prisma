datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(CLIENT)
  googleId  String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  resource  String
  details   String?
  ipAddress String?
  status    String
  createdAt DateTime @default(now())

  @@index([action])
  @@index([createdAt])
}

enum Role {
  ADMIN
  CLIENT
}
